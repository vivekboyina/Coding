#include <bits/stdc++.h>
using namespace std;
int main() {
	// your code goes here
	int t;
	cin >> t;
	while(t--)
	{
	    long long n;
	    cin >> n;
	    string s;
	    cin >> s;
	    string o = s;
	    string k;
	    string ans = s;
	    int i = 0;
	    for(i = 0; i < s.length(); i++) if(s[i] == 'z') break;
